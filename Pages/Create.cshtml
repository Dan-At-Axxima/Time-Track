@page
@model TimeTrackerRepo.Pages.CreateModel
@{
}
<h2>Add Employee</h2>
<form method="post" class="p-4 border rounded">
    <div class="row mb-3">
        <div class="col-md-2">
            <label asp-for="EmployeeAndRates.EmployeeNumber" class="form-label"></label>
            <input asp-for="EmployeeAndRates.EmployeeNumber" class="form-control" type="text" maxlength="4" minlength="4" pattern="\d{4}" required />
        </div>
        <div class="col-md-5">
            <label asp-for="EmployeeAndRates.FirstName" class="form-label"></label>
            <input asp-for="EmployeeAndRates.FirstName" class="form-control" />
        </div>
        <div class="col-md-5">
            <label asp-for="EmployeeAndRates.LastName" class="form-label"></label>
            <input asp-for="EmployeeAndRates.LastName" class="form-control" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.Email" class="form-label"></label>
            <input asp-for="EmployeeAndRates.Email" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="EmployeeAndRates.Active" class="form-label"></label>
            <select asp-for="EmployeeAndRates.Active" class="form-select">
                <option value="true" selected>Yes</option>
                <option value="false">No</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="EmployeeAndRates.DDARates" class="form-label"></label>
            <input asp-for="EmployeeAndRates.DDARates" class="form-control" />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <label asp-for="EmployeeAndRates.HoursPerDay" class="form-label"></label>
            <input asp-for="EmployeeAndRates.HoursPerDay" class="form-control" maxlength="2" />
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <button type="submit" class="btn btn-secondary" asp-page-handler="Cancel">Cancel</button>
    </div>
</form>
