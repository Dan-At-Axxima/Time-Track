@page
@model TimeTrackerRepo.Pages.EditModel
@{
    ViewData["Title"] = "Edit Employee";
}

<h2>Edit Employee</h2>

<form method="post" class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.FirstName" class="form-label">First Name</label>
            <input asp-for="EmployeeAndRates.FirstName" class="form-control" />
            <span asp-validation-for="EmployeeAndRates.FirstName" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.LastName" class="form-label">Last Name</label>
            <input asp-for="EmployeeAndRates.LastName" class="form-control" />
            <span asp-validation-for="EmployeeAndRates.LastName" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.Email" class="form-label">Email</label>
            <input asp-for="EmployeeAndRates.Email" class="form-control" />
            <span asp-validation-for="EmployeeAndRates.Email" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.EmployeeNumber" class="form-label">Employee Number</label>
            <input asp-for="EmployeeAndRates.EmployeeNumber" class="form-control" readonly />
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.HoursPerDay" class="form-label">Hours per Day</label>
            <input asp-for="EmployeeAndRates.HoursPerDay" class="form-control" />
            <span asp-validation-for="EmployeeAndRates.HoursPerDay" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="EmployeeAndRates.AxximaRates" class="form-label">Rate</label>
            <input asp-for="EmployeeAndRates.AxximaRates" class="form-control" />
            <span asp-validation-for="EmployeeAndRates.AxximaRates" class="text-danger"></span>
        </div>
    </div>

        <div class="col-md-6 d-flex align-items-center">
            <div class="form-check">
                <input type="checkbox" asp-for="EmployeeAndRates.Active" class="form-check-input" />
                <label asp-for="EmployeeAndRates.Active" class="form-check-label">Active</label>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="submit"  class="btn btn-secondary">Cancel</button>
    </div>
</form>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
