    </div>
</div>




<script>
let sDate = $('#startDateValue').val();
let eDate = $('#endDateValue').val();
 let d1 = makeJavaScriptDate(sDate);
 let d2 = makeJavaScriptDate(eDate);
$(document).ready(function() {
    $("#startDate").kendoDatePicker({
        change: function() {
            let newStartDate =kendo.toString(this.value(),"yyyy-MM-dd");
            console.log('the new date is ', newStartDate);
        },
        format: "yyyy-MM-dd",
        value: d1
    });
     $("#endDate").kendoDatePicker({
        format: "yyyy-MM-dd",
        value: d2
    });
})
</script>
