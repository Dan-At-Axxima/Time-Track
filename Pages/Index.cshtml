<script>
function getDatePortion(date) {
    if (!(date instanceof Date) || Number.isNaN(date.getTime())) return null;
    return new Date(date.getFullYear(), date.getMonth(), date.getDate());
}

function makeJavaScriptDate(dateString) {
    var cleaned = dateString.replace(/['"]+/g, '').trim();
    var values = cleaned.split('-');
    if (values.length != 3) values = cleaned.split(',');
    if (values.length === 3) {
        var year = parseInt(values[0], 10);
        var month = parseInt(values[1], 10);
        var day = parseInt(values[2], 10); // parseInt stops at space, OK for "01 00:00:00.000"
        return new Date(year, month - 1, day);
    }
    return null;
}

function formatYYYYMMDD(date) {
    var y = date.getFullYear();
    var m = String(date.getMonth() + 1).padStart(2, '0');
    var d = String(date.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + d;
}

// ALWAYS initialize from the API on load (ignore hidden input for initial value)
let storedDate = null;

async function initialSync() {
    try {
        const response = await fetch('/api/DataAccess/GetFrozenDate', { cache: 'no-store' });
        if (response.status === 204) {
            console.log('No frozen date from API (204).');
            return;
        }
        if (!response.ok) {
            console.error('Failed to fetch frozen date:', response.status, response.statusText);
            return;
        }

        const text = (await response.text()).trim();
        console.log('Raw input from API is:', text);

        const apiDate = makeJavaScriptDate(text);
        if (!apiDate) {
            console.warn('Unparseable API date:', text);
            return;
        }

        const apiDatePortion = getDatePortion(apiDate);
        if (!apiDatePortion) {
            console.warn('API date portion is null.');
            return;
        }

        // Set our baseline storedDate from API (no reload here)
        storedDate = apiDatePortion;

        // Keep the hidden input in sync (harmless if not present)
        const input = document.getElementById('frozenDate');
        if (input) input.value = formatYYYYMMDD(apiDatePortion);
    } catch (err) {
        console.error('initialSync error:', err);
    }
}

// --- SignalR wiring ---
const connection = new signalR.HubConnectionBuilder()
    .withUrl("/hubs/frozenDate")
    .withAutomaticReconnect()
    .build();

// Handle push from server
connection.on("FrozenDateChanged", function (newDateString) {
    try {
        const apiDate = makeJavaScriptDate(newDateString);
        if (!apiDate) return;

        const apiDatePortion = getDatePortion(apiDate);
        const storedDatePortion = getDatePortion(storedDate);

        console.log('SignalR push -> API date portion:', apiDatePortion);
        console.log('SignalR push -> Stored date portion:', storedDatePortion);

        // If we somehow don't have a stored baseline yet, initialize it and skip reload
        if (!storedDatePortion) {
            storedDate = apiDatePortion;
            const input = document.getElementById('frozenDate');
            if (input && apiDatePortion) input.value = formatYYYYMMDD(apiDatePortion);
            return;
        }

        if (apiDatePortion && storedDatePortion && apiDatePortion.getTime() !== storedDatePortion.getTime()) {
            window.location.reload();
        } else {
            console.log('Frozen date already matches (no refresh).');
        }
    } catch (err) {
        console.error('Error handling FrozenDateChanged:', err);
    }
});

// On reconnect (e.g., waking laptop), do a quick catch-up check
connection.onreconnected(() => { initialSync(); });

// Start: initialize from API first, then connect SignalR
(async function () {
    await initialSync();
    try {
        await connection.start();
    } catch (err) {
        console.error('SignalR connection error:', err);
    }
})();
</script>












