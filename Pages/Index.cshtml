 <script>
function formatTotals(sheet) {
    // formatting for column totals
    let range = sheet.range(1, 0, 1, 3);
    range.merge();
    range = sheet.range(1, 0, 1, 1);
    range.value('Total');
    let cols = $('#numberOfDaysInMonth').val();
    let firstCol = $('#firstColumn').val();
    range = sheet.range(1, firstCol, 1, cols);
    range.textAlign('right');
    range.color("black");
    range.bold(true);

    // formatting for row totals
    let rowsCount = sheet._rows._count;
    range = sheet.range(0, firstCol - 1, 1, 1);
    range.value('Total');
    range.textAlign("center");
    range = sheet.range(1, firstCol - 1, rowsCount - 1, 1);
    range.textAlign("right");
    range.color("black");
    range.bold(true);

    let colsCount = sheet._columns._count;


    range = sheet.range(0, 0, rowsCount, colsCount);
  //  range.enable(false);

//    range = sheet.range()
}
 </script>
 <script>
     function addColumnTotals(sheet) {
    let columnsCount = sheet._columns._count;
    let totalsColumn = $('#firstColumn').val();
    for (var c = totalsColumn; c < columnsCount; c++) {
        var range = sheet.range(1, c, 1, 1);
        var string = "=" + "addColumn(" + c + ")";
 //       console.log('the formula is ', string);
        range.formula(string);
    }
}
 </script>

 <script>
 function addRowTotals(sheet) {
    var rowsCount = sheet._rows._count;
    var columnsCount = sheet._columns._count;
    if (rowsCount > 1) {
        for (r = 1; r < rowsCount; r++) {
            var range = sheet.range(r, 3, 1, 1);
            var values = range.values();
            var string = "=" + "AddRows(" + r + ")";
            range.formula(string);
        }
    }
}
</script>
 <script>
     function addTheRowTitles(sheet){
         var rowTitles = @Html.Raw(Json.Serialize(Model.RowTitles));
        var columnTitles = $('#columnTitles').val();
         var columnTitlesArray = columnTitles.split(',');
         var newRowTitles = rowTitles.map(function(str) {
             return str.split(",");
         })
         let count = parseInt($('#totalRows').val());
         var r1 = sheet.range(2, 0, count + 1, 4);
         r1.values(newRowTitles);

         let cols = sheet._columns._count;
         let rows = sheet._rows._count;
         for (let i = 4; i < columnTitlesArray.length; i++) {
             var range = sheet.range(0, i, 1, 1);
             let colHeader = columnTitlesArray[i];
            let dateObject = makeJavaScriptDate(colHeader);
            let day = dateObject.getDay();
            if(day==0 || day==6){
                range = sheet.range(0, i, rows, 1);
                range.background("#F5F5F5");
            }
         }
        console.log('row titles are done');

     }
 </script>
 <script>
   function  AddTheComments(sheet){
         var comments = @Html.Raw(Json.Serialize(Model.ReturnCommentList));
     //  console.log('comments are: ', comments);
         if(comments !=undefined && comments.length>0){
             for (i = 0; i < comments.length; i++) {
                 let row = comments[i].row+2;
                 let date = comments[i].date;
                 let column = comments[i].column;
                 let comment = comments[i].comment;
                 let hours = comments[i].hours;
                 var range = sheet.range(row,column, 1, 1);
                 range.comment(comment);
                 range.value(hours);
                 //console.log('date is ', date);
                 //console.log('row is', row);
                 //console.log('column is', column);
             }
         }
     }
 </script>
 <script>
function addStringValues(sheet) {
    let borderRowCount = parseInt($('#nonChargeableRows').val());
    let totalRows = parseInt($('#totalRows').val()-2);
    let numberOfCols =   sheet._columns._count;
    sheet.resize(totalRows , sheet._columns._count);

    range = sheet.range(2, 4, totalRows - 2,numberOfCols-4);
    range.textAlign('right');
    range = sheet.range(0, 0, totalRows,numberOfCols);
    range.color("black");
    range = sheet.range(0, 0, 2,numberOfCols);
    let extraFreezeColumns = parseInt($('#extraFreezeColumns').val());
    range = sheet.range(0, 0, totalRows,4+extraFreezeColumns);
    range.enable(false); 
//    range.bold(true);

    sheet.columnWidth(1, 150);
    sheet.columnWidth(2, 150);
    
    addTheRowTitles(sheet);
    AddTheComments(sheet);
    range = sheet.range(borderRowCount+1,0,1,numberOfCols); 
    if ((borderRowCount + 1) < totalRows) {
        range.borderBottom({ size: 3, color: "black" });
    };
}
</script>

