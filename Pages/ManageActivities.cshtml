<script>
    function addRemoveAssignmentRecord(e,action) {
        var id = @Html.Raw(Model._httpContextAccessor.HttpContext.Session.GetString("currentUser"));
        var baseURL = $('#baseURL').val();
        var actionURL = action=='remove' ? $('#removeAssignmentURL').val() : $('#addAssignmentURL').val() ;
        var fullURL = baseURL + actionURL;
        console.log('full url is: ', fullURL);
        var data = {
            Id: id,
            Client: e.client,
            Project: e.project,
            Activity: e.activity
        };
        var newData = JSON.stringify(data);
        console.log('the data isis: ', newData);
        $.ajax({
            async: false,
            url: fullURL,
            type: 'POST',
            contentType: "application/json",
            data: newData,
        }).done(function(e) {
                console.log('the action was: ',action);
                location.reload();
            }).fail(function(error) {
                console.log('save error');
            }).always(function() {
                console.log('done')
            });      
}
</script>
