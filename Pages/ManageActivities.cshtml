                                locked: true,
                                lockable: false,
                                width: 150
                            }, {
                                field: "project",
                                title: "Project",
                                width: 200
                            }, {
                                field: "activity",
                                title: "Activity",
                                width: 150
                            }
@*                            {
                                command: ["destroy"],title: "", width: 200, attributes: { style: "text-align: center" } 
                            }
*@                        ]
                    });

                });
                $(document).ready(function() {
                    var toobarButtons = $("#toolbarOptions").val();
                    var activityData =  @Html.Raw(Json.Serialize(Model.ActivityList));
                       var activityDataSource = new kendo.data.DataSource({
                        transport: {
                            read: function(e) {
                                e.success(activityData);
                            },
                            destroy: function(e) {
                                var res = makeRemoveAssignmentRecord(e.data);
                                console.log('destroy ',res);
                                e.success();
                            }
                        },
                        error: function(e) {
                            console.log("we got an error due");
                        },
                        batch: false,
                        pageSize: 999,
                        schema: {
                            model: {
                                id: "id",
                                fields: {
                                    client: {editable: false},
                                    project: {editable: false},
                                    activity: {editable: false},
                                }
                            }
                        }
                    });
                    var toolbar = 
                    $("#axximaGrid").kendoGrid({
                        dataSource: activityDataSource,
                        height: 800,
                        sortable: true,
                        reorderable: true,
                        resizable: true,
                        editable: "inline",
                        filterable: true,
                        columnMenu: true,
                        selectable: "single",
                        pageable: false,
                        columns: [ {
                                field: "client",
                                title: "Client",
                                locked: true,
                                lockable: false,
                                width: 150
                            }, {
                                field: "project",
                                title: "Project",
                                width: 210
                            }, {
                                field: "activity",
                                title: "Activity",
                                width: 150
                            }
@*                            {
                                command: ["destroy"],title: "", width: 200, attributes: { style: "text-align: center" } 
                            }
*@                        ]
                    });
                    var admin = $('#isAdministrator').val();
                    console.log('admin value is: ',admin);
                    if (admin) {
                        toolbar.data("kendoGrid").setOptions({
                            toolbar: [{ id:'addNew', name: 'addNew', text: 'Add New Activity' }, 'search']
                        })
                        $(".k-grid-addNew").click(function(e) {
                            var modalContainer = document.getElementById("modal-container");
                   //         console.log('open model is wtf ', openModal);
                            modalContainer.style.display = "block";
                            modalContainer.addEventListener("click", function(e) {
                                if (e.target == modalContainer) {
                                  modalContainer.style.display = "none";
                                }
                            });
                        });
                    }
                    else{
                        toolbar.data("kendoGrid").setOptions({
                            toolbar: ['search']
                        })
                    }
                });


                $(document).ready(function() {
                      function onClick(e) {
                          var button = $(e.event.target).closest(".k-button").attr("id");
                          if (button == "addButton") {
                              var grid = $("#axximaGrid").data("kendoGrid");
                              var selectedItem = grid.dataItem(grid.select());
                              if (selectedItem == 'undefined' || selectedItem == null) {
                                  alert('no records selected');
                                  return;
                              }
                              var data = addRemoveAssignmentRecord(selectedItem,'add');
                              console.log('selected item to add ', selectedItem.activity, ' ', selectedItem.project, ' ', selectedItem.client);
                          }
                          if (button == "removeButton") {
                              var grid = $("#userGrid").data("kendoGrid");
                              var selectedItem = grid.dataItem(grid.select());
                              if (selectedItem == 'undefined' || selectedItem == null) {
                                  alert('no records selected');
                                  return;
                              }
                              var data = addRemoveAssignmentRecord(selectedItem,'remove');
                              console.log('selected item for removal ', data);
                          }
                    }
                     $("#addButton").kendoButton({
                         click: onClick
                
                    });
                     $("#removeButton").kendoButton({
                         click: onClick
                
                    });

                })
        </script>

