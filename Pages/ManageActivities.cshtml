                            read: function(e) {
                                e.success(assignmentsData);
                            },
                            destroy: function(e) {
                                var res = makeRemoveAssignmentRecord(e.data);
                                console.log('destroy ',res);
                                e.success();
                            }
                        },
                        error: function(e) {
                            console.log("we got an error dude");
                        },
                        batch: false,
                        pageSize: 999,
                        schema: {
                            model: {
                                id: "id",
                                fields: {
                                    client: {editable: false},
                                    project: {editable: false},
                                    activity: {editable: false},
                                }
                            }
                        }
                    });
                    $("#userGrid").kendoGrid({
                        dataSource: dataSource,
                        height: 800,
                        sortable: true,
                        reorderable: true,
                        resizable: true,
                        selectable: "single",
                        editable: "inline",
                        filterable: true,
                        columnMenu: true,
                        toolbar: ["search"],
                        pageable: false,
                        columns: [ {
                                field: "client",
