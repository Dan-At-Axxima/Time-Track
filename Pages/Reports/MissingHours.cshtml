@page
@model TimeTrackerRepo.Pages.Reports.MissingHoursModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

@{
    ViewData["Title"] = "Missing Hours";
}

<h2>Missing Hours</h2>

<div class="mb-3">
    <strong>Start Date:</strong> @Model.StartDate.ToString("yyyy-MM-dd")
    <span class="ms-3"></span>
    <strong>End Date:</strong> @Model.EndDate.ToString("yyyy-MM-dd")
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">
        @Model.StatusMessage
    </div>
}

@if (Model.Rows.Count > 0)
{
    <form method="post" asp-page-handler="ExportToExcel" class="mb-3">
        <input type="hidden" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="IncludeAllocations" value="@Model.IncludeAllocations" />

        <button type="submit" class="btn btn-outline-secondary">
            Export to Excel
        </button>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Employee Number</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Date</th>
                    <th>Hours</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.EmployeeNumber</td>
                        <td>@row.FirstName</td>
                        <td>@row.LastName</td>
                        <td>@row.Date.ToString("yyyy-MM-dd")</td>
                        <td>@row.Hours</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}