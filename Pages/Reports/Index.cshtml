@page
@model TimeTrackerRepo.Pages.Reports.IndexModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

@{
    ViewData["Title"] = "Reports";

    var startDateText = Model.StartDate.ToString("yyyy-MM-dd");
    var endDateText = Model.EndDate.ToString("yyyy-MM-dd");
    var includeAllocationsText = Model.IncludeAllocations.ToString().ToLower();

    var missingHoursUrl = $"/Reports/MissingHours?startDate={startDateText}&endDate={endDateText}&includeAllocations={includeAllocationsText}";
    var extractUrl = $"/Reports/Extract?startDate={startDateText}&endDate={endDateText}&includeAllocations={includeAllocationsText}";
    var wipUrl = $"/Reports/Wip?startDate={startDateText}&endDate={endDateText}&withAllocation={includeAllocationsText}";
}

<h2>Reports</h2>

<form method="post" class="mt-3">
    <div class="row g-2 align-items-end">

        <div class="col-md-2">
            <div class="form-check mt-4">
                <input asp-for="IncludeAllocations" class="form-check-input" />
                <label asp-for="IncludeAllocations" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <label asp-for="StartDate" class="form-label"></label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="EndDate" class="form-label"></label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>

    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info mt-3">
        @Model.StatusMessage
    </div>
}

<hr class="mt-4" />

<h4 class="mt-3">Reports</h4>

<div class="mt-3 d-flex flex-wrap gap-2">
    <a class="btn btn-outline-primary rounded-pill px-4" href="@extractUrl">
        Summary
    </a>

    <a class="btn btn-outline-primary rounded-pill px-4" href="@wipUrl">
        WIP
    </a>

    <a class="btn btn-outline-primary rounded-pill px-4" href="@missingHoursUrl">
        Missing Hours
    </a>

    <button type="button" class="btn btn-outline-primary rounded-pill px-4"
            onclick="showUnderConstruction('All Reports')">
        All Reports
    </button>
</div>

<div id="underConstructionMessage" class="alert alert-warning mt-3 d-none"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function showUnderConstruction(reportName) {
            const msg = document.getElementById("underConstructionMessage");
            msg.textContent = reportName + " is under construction.";
            msg.classList.remove("d-none");

            setTimeout(() => {
                msg.classList.add("d-none");
            }, 3000);
        }
    </script>
}