@page
@model TimeTrackerRepo.Pages.Reports.WipModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")]

@{
    ViewData["Title"] = "Axxima WIP Detail Report";
}

<style>
    .wip-report-table td,
    .wip-report-table th {
        vertical-align: top;
    }

        .wip-report-table td:nth-child(7) {
            white-space: normal;
        }
</style>

<h2>Axxima WIP Detail Report</h2>

<div class="text-muted mb-3">
    Period: @Model.StartDate.ToString("yyyy-MM-dd") to @Model.EndDate.ToString("yyyy-MM-dd")
    &nbsp;•&nbsp; Records: @Model.Rows.Count
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">
        @Model.StatusMessage
    </div>
}

@if (Model.Rows.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle wip-report-table">
            <thead class="table-light">
                <tr>
                    <th>Client</th>
                    <th>Activity</th>
                    <th>Associate</th>
                    <th>Date</th>
                    <th class="text-end">Time Spent</th>
                    <th class="text-end">Axxima Rates</th>
                    <th>Description</th>
                    <th>Slip ID</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@($"{row.Project}:{row.Client}")</td>
                        <td>@row.Activity</td>
                        <td>@row.LastName</td>
                        <td>@row.Date.ToString("M/d/yyyy")</td>
                        <td class="text-end">@CalcDecimalTime(row.Seconds)</td>
                        <td class="text-end">@row.AxximaRates.ToString("N2")</td>
                        <td>@row.Comment</td>
                        <td>@row.SlipId</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-warning">
        No records found for the selected criteria.
    </div>
}

@functions {
    private static string CalcDecimalTime(double seconds)
    {
        int h = (int)(seconds / 3600);
        int remainingSeconds = (int)(seconds - (h * 3600));
        double fractionalHours = (double)remainingSeconds / 3600;
        double value = h + fractionalHours;
        return value.ToString("0.000000");
    }
}