@page
@model TimeTrackerRepo.Pages.Reports.WipModel
@* @attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator")] *@

@{
    ViewData["Title"] = Model.ReportTitle;
}

<style>
    .wip-report-table td,
    .wip-report-table th {
        vertical-align: top;
    }

        .wip-report-table td:nth-child(7) {
            white-space: normal;
        }

    .wip-divider td {
        border-top: 2px solid #6c757d !important;
        padding: 0 !important;
        height: 0.35rem;
        background: #fff;
    }

    .wip-total-row td {
        font-weight: 600;
        background-color: #f8f9fa;
    }

    .wip-grand-total td {
        font-weight: 700;
        background-color: #e9ecef;
    }
</style>

<h2>@Model.ReportTitle</h2>

<div class="text-muted mb-3">
    Period: @Model.StartDate.ToString("yyyy-MM-dd") to @Model.EndDate.ToString("yyyy-MM-dd")
    &nbsp;•&nbsp; Records: @Model.Rows.Count
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">
        @Model.StatusMessage
    </div>
}

@if (Model.Rows.Count > 0)
{
    <div class="mb-3">
        <a asp-page-handler="Export"
           asp-route-StartDate="@Model.StartDate.ToString("yyyy-MM-dd")"
           asp-route-EndDate="@Model.EndDate.ToString("yyyy-MM-dd")"
           asp-route-WithAllocation="@Model.WithAllocation"
           asp-route-IFRSOnly="@Model.IFRSOnly"
           asp-route-CompanyCode="@Model.CompanyCode"
           class="btn btn-primary">
            Export Excel
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle wip-report-table">
            <thead class="table-light">
                <tr>
                    <th>Client</th>
                    <th>Activity</th>
                    <th>Associate</th>
                    <th>Date</th>
                    <th class="text-end">Time Spent</th>
                    <th class="text-end">Axxima Rates</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.DisplayRows)
                {
                    if (row.RowType == TimeTrackerRepo.Models.Reports.WipDisplayRowType.Divider)
                    {
                        <tr class="wip-divider"><td colspan="7"></td></tr>
                    }
                    else if (row.RowType == TimeTrackerRepo.Models.Reports.WipDisplayRowType.Detail)
                    {
                        <tr>
                            <td>@row.ClientProject</td>
                            <td>@row.Activity</td>
                            <td>@row.Associate</td>
                            <td>@row.DateText</td>
                            <td class="text-end">
                                @{
                                    var t = row.TimeText;
                                    var i = t?.IndexOf('.') ?? -1;
                                    @((i >= 0 && t.Length > i + 3) ? t.Substring(0, i + 3) : t)
                                }
                            </td>
                            <td class="text-end">@row.AmountText</td>
                            <td>@row.Description</td>
                        </tr>
                    }
                    else if (row.RowType == TimeTrackerRepo.Models.Reports.WipDisplayRowType.GrandTotal)
                    {
                        <tr class="wip-grand-total">
                            <td colspan="3"></td>
                            <td>@row.Label</td>
                            <td class="text-end">
                                @{
                                    var t = row.TimeText;
                                    var i = t?.IndexOf('.') ?? -1;
                                    @((i >= 0 && t.Length > i + 3) ? t.Substring(0, i + 3) : t)
                                }
                            </td>
                            <td class="text-end">@row.AmountText</td>
                            <td></td>
                        </tr>

                        <!-- spacer row -->
                        <tr><td colspan="7">&nbsp;</td></tr>
                    }
                    else
                    {
                        <tr class="wip-total-row">
                            <td colspan="3"></td>
                            <td>@row.Label</td>
                            <td class="text-end">
                                @{
                                    var t = row.TimeText;
                                    var i = t?.IndexOf('.') ?? -1;
                                    @((i >= 0 && t.Length > i + 3) ? t.Substring(0, i + 3) : t)
                                }
                            </td>
                            <td class="text-end">@row.AmountText</td>
                            <td></td>
                        </tr>

                        <!-- spacer row -->
                        <tr><td colspan="7">&nbsp;</td></tr>
                    }
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-warning">
        No records found for the selected criteria.
    </div>
}