 <script>
    var data = activities;
    var nextID = activities.length + 1;
console.log(nextID);

    function getIndexById(id) {
        var idx,
            l = activities.length;
        for (var j = 0; j < l; j++) {
            if (data[j].ActivityID == id) {
                return j;
            }
        }
        return null;
    }

        var thisDefaultValue = $('#selectedActivity').val();
        $(document).ready(function () {
            var dataSource = new kendo.data.DataSource({
                transport: {
                    read: function(e) {
                        e.success(data);
                    },
                    update: function(e) {
                        data[getIndexById(e.data.ActivityID)] = e.data;
                        e.success();
                    },
                    create: function(e) {
                        e.data.ActivityID = nextID++;
                        data.push(e.data);
                        e.success(e.data);
                    },
                    destroy: function(e) {
                        data.splice(getIndexById(e.data.ProductID), 1);
                        e.success();
                    }
                },
                error: function(e) {
                    alert("Status: " + e.status + "; Error message: " + e.errorThrown);
                },
                batch: false,
                pageSize: 20,
                schema: {
                    model: {
                        id: "ActivityID",
                        fields: {
                            ActivityID: { editable: false, nullable: true },
                            activity: { type: "string",  defaultValue: thisDefaultValue },
                            date: { type: "date", format: "{0:yyyy-MM-dd}"},
                            comment: { type: "string" },
                            hours: { defaultValue: {hoursID: 0, hoursValue: "0"} },
                            minutes: { defaultValue: {minutesID: 0, minutesValue: ":00"} }
                        }
                    }
                }
         });
          
           var grid = $("#grid").kendoGrid({
               toolbar: ["create",
                   {template: kendo.template($("#template").html())},
                   { template: kendo.template($("#datetemplate").html()) }
               ],
                dataSource: dataSource,
                edit: function(e) {
                    if (e.model.isNew() && !e.model.dirty) {
                         e.container
                            .find("input[name=activity]").attr("disabled", false);
                        e.model.set("activity", $('#selectedActivity').val());
                         e.container
                            .find("input[name=Activity]").attr("disabled", true);
                        e.model.set("popupdate", $('#defaultDate').val());
                        e.model.set("date", $('#defaultDate').val());
                        var grid = $("#grid").data("kendoGrid");
                        grid.select("tr:eq(0)");
                        var ignore = $('#ignoreChange').val();
                        console.log('selected row');
                        console.log(ignore);
                        var newCell = grid.tbody.find("tr").eq(0).find("td").eq(1);
                        if (ignore == 'false') {
                            $('#ignoreChange').val('true');
                            grid.editCell(newCell)
                        };
                    }
                    hoursdropdown(e);
                    minutesdropdown(e);
                    setMinimumDate(e);


               },
                pageable: true,
                height: 550,
//                toolbar: ["create"],
                columns: [
                    { field:"activity",title:"Activity",width:'20%', },
                    { field: "date", title: "Date", format: "{0:MM/dd/yyyy}", validation: {required: true}, width: "130px" },
                    { field: "hours", title: "Hours",   editor: hoursDropDownEditor, template: "#=hours.hoursValue#", width:'5em' },
                    { field: "minutes", title: "Minutes", width: "75px", editor: minutesDropDownEditor, template: "#=minutes.minutesValue#", width:'5em'  },
                    { field: "comment", title: "Comment", validation: {required: true},editor: textareaEditor,width:'50em', },
                    { command: ["edit", "destroy"], title: " ", width: "150px" }],
               editable: {
                   mode: "popup",
                   template: kendo.template($("#popup_editor").html())
               } ,
               save: function(e) {
                   var newRecord = e.model.toJSON();
                   console.log(newRecord.hours.hoursValue);
                   var newActivity = newRecord.activity;
                   var newDate = newRecord.date;
                   var grid = $("#grid").data("kendoGrid");
                   var ds = grid.dataSource.view().toJSON();
                   if (ds != 'undefined' && ds.length>0) {
                       let output = makenewrow(ds[0]);

                       console.log(outPut);
                       var jsonOutPut = JSON.parse(outPut);
                       console.log(jsonOutPut);
                       for (let i = 0; i < ds.length; i++) {
                           if (ds[i].ActivityID != null) {
                               var dsActivity = ds[i].activity;
                               var dsDate = ds[i].date;
                               console.log(dsActivity, newActivity);
                               //    console.log(newActivity, newDate);
                               if (dsActivity === newActivity) {
                                   console.log(dsActivity);
                                   alert('This Activity & Date already exists in this Grid');
                                   e.preventDefault();
                                   return;
                               }
                           }
                       }
                       return;
                   }

               },
               dataBound: function(e) {
                   setDatePicker(e);
               },           
            });
        });
        
function setDatePicker(e) {
     $("#datepicker").kendoDatePicker({
        value: $('#defaultDate').val(),
        change: function(e) {
            $('#defaultDate').val(this.value());
            console.log(this.value());
            console.log($('#defaultDate').val());

        },
     //   min: setMinimumDate(),
       
     });
};

         function onDDLChange(e) {
        var element = e.sender.element;
        var row = element.closest("tr");
        var grid = $("#grid").data("kendoGrid");
        var dataItem = grid.dataItem(row);
        dataItem.set("value", e.sender.value());
    };

