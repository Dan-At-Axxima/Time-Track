@page
@model TimeTrackerGrid
@{
    ViewData["Title"] = "TimeTracker Batch Entry";
}
<h1>@ViewData["Title"]</h1>


@Html.HiddenFor(m => m.SelectedActivity, new { @id = "selectedActivity" })
@Html.HiddenFor(m => m.SelectedActivityDate, new { @id = "selectedActivityDate" })
